{
  "name": "sdpm-composer",
  "description": "Composer agent for spec-driven-presentation-maker. Writes slide JSON, builds PPTX, measures, and polishes autonomously. No user interaction.",
  "prompt": "file://../../prompts/system-prompt.md",
  "tools": [
    "@sdpm"
  ],
  "allowedTools": [
    "@sdpm"
  ],
  "mcpServers": {
    "sdpm": {
      "command": "uv",
      "args": ["run", "--directory", "mcp-local", "python", "server.py"],
      "timeout": 120000
    }
  },
  "resources": [
    "skill://skill/references/workflows/create-new-2-compose.md",
    "skill://skill/references/workflows/slide-json-spec.md"
  ]
}
